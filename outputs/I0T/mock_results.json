    "exp-figure3": {
      "evidence_in_paper": "figure-3",
      "summary": "Normalized embedding activations for image and text encoders. Long-CLIP (column 1): peak negative activation at image dim 93, positive peaks at text dims 134 and 313, with severe modality gap CD=0.9904. Clipping (column 2): peaks still present after clipping at ±0.1 range, severe gap persists. Mind-the-Gap (MG, column 3): peaks remain visible, low severity but artificial shift. I0T_post (column 4): NO peak activations, mean activations close to zero across all hidden dimensions, CD=0.0102 (near zero). I0T effectively removes modality-specific characteristics that other methods leave intact."
    },
    "exp-figure4": {
      "evidence_in_paper": "figure-4",
      "summary": "BLIP vs I0T methods on parameters efficiency. BLIP has substantially more parameters than I0T variants. I0T_async (354m) and I0T_post (353m) achieve 94.68% and 47.74% lower centroid distance than BLIP while maintaining similar relative correlation on Flickr-Expert. 2.5x fewer parameters than BLIP."
    },
    "exp-figure5": {
      "evidence_in_paper": "figure-5",
      "summary": "Cosine similarity distributions. CLIP-S: min=0.150, max=0.350, range=0.200, narrow skewed clustered around 0.25. PAC-S: min=0.100, max=0.400, range=0.300, similar narrow distribution. IOT-S (I0T_post): min=-0.349, max=0.660, range=1.009 (~5x wider than CLIP-S), non-skewed with mean approximately 0.0. IOT-S enables intuitive scoring: negative pairs below 0, positive pairs above 0. +21% score for correct pairs vs CLIP-S, -20% for incorrect."
    },
    "exp-table8": {
      "evidence_in_paper": "table-8",
      "summary": "Ablation comparing BN* training without and with MCSIE loss. Without MCSIE: CD=0.442, LS=0.999, I2T=70.9, T2I=72.3. With MCSIE: CD=0.479, LS=0.996, I2T=72.5, T2I=73.8. MCSIE produces slightly higher CD (worse on modality gap by 0.04 absolute) but markedly better retrieval (+1.6 I2T, +1.5 T2I). MCSIE benefit is in retrieval, not in CD itself; paper interprets as MCSIE enabling robust learning of modality-specific characteristics."
    }
