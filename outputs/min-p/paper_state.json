    {
      "name": "Standard Sampling (baseline for creative writing comparison)",
      "type": "fixed temperature-only sampling at τ=1.0",
      "reference": null,
      "source_section": "sec-5.2.3"
    }
  ],
  "metrics": [
    {
      "name": "Accuracy",
      "definition": "Percentage of correctly answered questions on GPQA Main and GSM8K CoT benchmarks.",
      "source_section": "sec-5.1"
    },
    {
      "name": "Win Rate",
      "definition": "Proportion of comparisons where the evaluated model's output is preferred over a baseline by the AlpacaEval LLM judge (GPT-4 Turbo).",
      "source_section": "sec-5.2.3"
    },
    {
      "name": "Length-Controlled Win Rate (LC-Win Rate)",
      "definition": "Win rate adjusted for output length bias to isolate quality from verbosity.",
      "source_section": "sec-5.2.3"
    },
    {
      "name": "Entropy of Correct Predictions",
      "definition": "Average continuous entropy of correct chain-of-thought answers, measured via language model embeddings and empirical covariance to quantify diversity.",
      "source_section": "sec-5.2.2"
    },
    {
      "name": "Human Quality Rating",
      "definition": "Mean subjective rating (1-10) of overall coherence, relevance and quality of generated stories by human evaluators.",
      "source_section": "sec-6"
    },
    {
      "name": "Human Diversity Rating",
      "definition": "Mean subjective rating (1-10) of how creative and distinct the three presented stories appeared to human evaluators.",
      "source_section": "sec-6"
    }
  ],
