  "expected_claims": [
    {
      "id": "claim-1",
      "claim_text": "On GPQA Main at τ=1.5, 2.0, and 3.0, min-p sampling achieves higher accuracy than top-p, temperature-only, and top-k sampling.",
      "evidence": "table-2",
      "verification_hint": "From Table 2 GPQA columns: at τ=1.5 min-p=28.13 vs top-p=24.78 vs temp-only=25.22 vs top-k=22.77; at τ=2.0 min-p=26.34 vs top-p=6.47 vs temp-only=5.80 vs top-k=16.52; at τ=3.0 min-p=24.55 vs top-p=0.46 vs temp-only=0.89 vs top-k=5.88. Min-p is highest at all 12 cells (3 temps × 4 methods comparison)."
    },
    {
      "id": "claim-2",
      "claim_text": "Min-p achieves a superior accuracy–diversity Pareto frontier compared to top-p on GSM8K CoT Self-Consistency.",
      "evidence": "figure-2",
      "verification_hint": "Plot accuracy vs entropy for each method's 20 configurations; confirm that min-p points dominate top-p in the upper-right region and the min-p Pareto frontier lies closer to the ideal top-right corner."
    },
    {
      "id": "claim-3",
      "claim_text": "In human evaluation, min-p scores higher than top-p on both quality and diversity across all temperature and diversity settings, with statistically significant differences at τ=3.0.",
      "evidence": "table-4",
      "verification_hint": "Check that for each (Temp, Diversity Setting) pair, min-p quality and diversity means exceed the corresponding top-p means; at T=3 high diversity, min-p quality 7.57 ± 0.23 vs top-p 7.11 ± 0.29, diversity 7.66 ± 0.20 vs 7.49 ± 0.24."
    },
    {
      "id": "claim-4",
      "claim_text": "Min-p scales to large models (123B parameters), retaining GPQA Main accuracy above 22% at τ=3.0 while top-p and temperature-only fall below 3%.",
      "evidence": "table-3a",
      "verification_hint": "In Table 3a, at τ=3.0, min-p accuracy = 22.77% vs top-p (p=0.9) = 2.01%, proving robust high-temperature reasoning."
    },
    {
      "id": "claim-5",
      "claim_text": "On AlpacaEval Creative Writing, min-p achieves higher win rates than temperature-only sampling at both τ=1.0 and τ=1.5, and exceeds top-p at τ=1.0.",
      "evidence": "table-3b",
      "verification_hint": "Min-p win rate: 52.01% at τ=1.0, 56.54% at τ=1.5. Compare against Temperature Only (49.97% / 53.18%) — min-p higher at both. Top-p at τ=1.0 = 50.43% — min-p higher; top-p at τ=1.5 is not reported in Table 3b."
    },
    {
      "id": "claim-6",
      "claim_text": "η-sampling and ε-sampling fail entirely at τ ≥ 2.0 (cannot produce results), while min-p remains practical and produces valid accuracy scores.",
      "evidence": "table-2",
      "verification_hint": "In Table 2 GPQA and GSM8K cols at τ=2.0 and τ=3.0: η/ε sampling rows are empty (could not complete evaluation); min-p sampling rows have valid scores (e.g. GPQA τ=2.0=26.34, τ=3.0=24.55)."
    },
    {
      "id": "claim-7",
      "claim_text": "Min-p dynamically adjusts its truncation threshold: in high-certainty contexts it preserves only top relevant tokens, while in low-certainty contexts it permits a diverse set, as illustrated by token probability comparisons in case studies.",
      "evidence": "table-1",
      "verification_hint": "In Table 1b, for the high-certainty prompt, min-p at τ=3 focuses on 'light' (80.9%) and 'sunlight' (19.1%), filtering out tokens like 'water', while top-p retains them."
    }
