{
  "paper_id": "min-p",
  "title": "Turning Up the Heat: Min-p Sampling for Creative and Coherent LLM Outputs",
  "venue": null,
  "code_url": null,
  "problem_definition": {
    "task": "Improve the quality-diversity trade-off in autoregressive text generation from large language models.",
    "input": "At each decoding step, the model's predicted probability distribution over the vocabulary for the next token, conditioned on the preceding context.",
    "output": "A sampled next token from a dynamically truncated subset of the vocabulary.",
    "evaluation_target": "min-p sampling should outperform existing sampling methods (top-p, top-k, temperature-only, η-sampling, ε-sampling, mirostat) at balancing coherence and diversity, especially at high temperatures, as measured by accuracy on reasoning benchmarks (GPQA, GSM8K), win rates on creative writing (AlpacaEval), and human preference scores."
  },
  "core_method": {
    "name": "min-p sampling",
    "one_line": "A dynamic truncation method that scales the minimum probability threshold by the probability of the most likely token, keeping only tokens whose probabilities are at least p_base × p_max, thereby adapting the sampling pool to the model's confidence at each step.",
    "atomic_steps": [
      {
        "id": "step-1",
        "description": "Retrieve the unnormalized logits vector for the next token from the language model.",
        "source_section": "sec-3",
        "depends_on_method": null
      },
      {
        "id": "step-2",
        "description": "Optionally divide logits by the temperature τ (if τ != 1.0) to control randomness.",
        "source_section": "sec-5.1",
        "depends_on_method": null
      },
      {
        "id": "step-3",
        "description": "Convert the (temperature-scaled) logits to probabilities using softmax.",
        "source_section": "sec-3",
        "depends_on_method": null
      },
      {
        "id": "step-4",
        "description": "Identify the maximum token probability p_max = max(probs).",
        "source_section": "sec-3",
        "depends_on_method": null
      },
      {
        "id": "step-5",
        "description": "Compute the dynamic truncation threshold scaled_min_p = p_base * p_max.",
        "source_section": "sec-3",
        "depends_on_method": null
      },
      {
        "id": "step-6",
        "description": "Create a boolean mask marking tokens whose probability is less than scaled_min_p as candidates for removal.",
        "source_section": "sec-3",
        "depends_on_method": null
      },
      {
        "id": "step-7",
        "description": "Sort token indices by original logit scores in descending order.",
        "source_section": "sec-3",
        "depends_on_method": null
      },
      {
        "id": "step-8",
        "description": "Modify the removal mask to keep at least min_tokens_to_keep tokens (default 1) by setting the top min_tokens_to_keep positions in the sorted order to not be removed.",
        "source_section": "sec-A.1",
        "depends_on_method": null
      },
      {
        "id": "step-9",
        "description": "Apply the final removal mask to the logits, setting the values of removed tokens to -inf (or a very low filter value).",
        "source_section": "sec-A.1",
        "depends_on_method": null
      },
      {
        "id": "step-10",
        "description": "Use the filtered logits for sampling (e.g., multinomial sampling) to select the next token.",
        "source_section": "sec-3",
        "depends_on_method": null
      }
    ],
    "settings": [
      {
        "id": "set-1",
        "name": "min-p (p_base=0.05)",
        "description": "Base threshold 0.05 – higher diversity setting, recommended range for creative tasks."
      },
      {
        "id": "set-2",
        "name": "min-p (p_base=0.1)",
        "description": "Base threshold 0.1 – balanced setting between coherence and diversity."
      },
      {
        "id": "set-3",
        "name": "min-p (p_base=0.2)",
        "description": "Base threshold 0.2 – lower diversity, used in human evaluation for conservative sampling."
      }
    ],
    "key_hyperparameters": [
      {
        "name": "p_base",
        "value": "0.05 or 0.1 (recommended); 0.2 used for low-diversity condition",
        "source_section": "sec-3.4"
      },
      {
        "name": "min_tokens_to_keep",
        "value": "1 (default)",
        "source_section": "sec-A.1"
      },
      {
        "name": "temperature (τ)",
        "value": "0.7 to 5.0 (main experiments use 0.7–4.0)",
        "source_section": "sec-5.1"
      }
    ]
  },
